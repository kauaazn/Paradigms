#include <stdio.h>

// Função que recebe os dados via PARÂMETROS e retorna o resultado
// Retorno: float (a média calculada)
// Parâmetros: n1 e n2 — os dados vêm de fora (do main)
// Diferença do exemplo1: os valores já chegam prontos, a função só processa
float calculaMedia(float n1, float n2){
        float media;
        media = (n1 + n2) / 2;
        return media;   // devolve o resultado para quem chamou
    }

int main(){
   float n1 = 2.2, n2 = 3.3, media;
   media = calculaMedia(n1, n2);    // passa os valores como argumento
   printf("Média = %f", media);
   return 0;
}
